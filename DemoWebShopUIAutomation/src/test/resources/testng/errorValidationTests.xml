<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="DemoWebShop Suite">
    <listeners>
        <listener class-name="com.wilsonmanaog.automation.listeners.TestListener"/>
    </listeners>

    <test name="Login Tests">
        <groups>
            <run>
                <include name="ErrorValidationTests"/>
            </run>
        </groups>
        <classes>
            <class name="com.wilsonmanaog.automation.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Register User Tests">
        <groups>
            <run>
                <include name="ErrorValidationTests"/>
            </run>
        </groups>
        <classes>
            <class name="com.wilsonmanaog.automation.tests.RegisterUserTest"/>
        </classes>
    </test>

    <test name="Search Product Tests">
        <groups>
            <run>
                <include name="ErrorValidationTests"/>
            </run>
        </groups>
        <classes>
            <class name="com.wilsonmanaog.automation.tests.SearchProductTest"/>
        </classes>
    </test>

</suite>
